// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
  "name": "${localWorkspaceFolderBasename}",
  "image": "mcr.microsoft.com/vscode/devcontainers/python:3.11",
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "runArgs": [
    "--name",
    "${localWorkspaceFolderBasename}"
  ],
  "containerEnv": {
    "UV_PROJECT_ENVIRONMENT": "/home/vscode/.cache/uv/.venv",
    "VIRTUAL_ENV": "/home/vscode/.cache/uv/.venv"
  },
  "mounts": [
    "source=cache,target=/workspaces/.cache/uv,type=volume,consistency=cached"
  ],
  "onCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh; $HOME/.cargo/bin/uv sync",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/home/vscode/.cache/uv/.venv/bin/python"
      },
      "extensions": [
        "charliermarsh.ruff",
        "GitHub.copilot-chat",
        "GitHub.copilot",
        "ms-python.mypy-type-checker",
        "ms-python.pylint",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow",
        "njpwerner.autodocstring",
        "ms-python.debugpy",
        "mhutchie.git-graph",
        "zh9528.file-size",
        "tamasfe.even-better-toml",
        "bierner.github-markdown-preview",
        "yzhang.markdown-all-in-one",
        "christian-kohler.path-intellisense",
        "esbenp.prettier-vscode",
        "jeffersonlicet.snipped",
        "ms-toolsai.tensorboard",
        "Gruntfuggly.todo-tree",
        "redhat.vscode-yaml",
        "adpyke.codesnap",
        "gitpod.gitpod-remote-ssh",
        "kisstkondoros.vscode-gutter-preview",
        "DavidAnson.vscode-markdownlint",
        "mechatroner.rainbow-csv",
        "ms-toolsai.jupyter",
        "GitLab.gitlab-workflow",
        "tamasfe.even-better-toml"
      ]
    }
  }
}